// PJ's Gumbo Platform — production database schema.
//
// Design notes:
//  - InventoryItem is the canonical "item" (food, packaging, supplies). Recipes
//    reference it through RecipeIngredient, so costing and stock never diverge.
//  - InventoryTransaction is an append-only ledger of every stock movement
//    (receive/use/adjust/waste/count) — the source of truth for on-hand & history.
//  - Money uses Decimal(10,2); quantities use Decimal(12,3).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Identity / RBAC
// ============================================================================

enum Role {
  OWNER
  MANAGER
  KITCHEN
  PREP
  EMPLOYEE
}

model User {
  id         String   @id @default(cuid())
  supabaseId String   @unique
  email      String   @unique
  name       String?
  phone      String?
  role       Role     @default(EMPLOYEE)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee              Employee?
  auditLogs             AuditLog[]
  inventoryTransactions InventoryTransaction[]
  wasteLogs             WasteLog[]
  cycleCounts           CycleCount[]
  purchaseOrders        PurchaseOrder[]
  productionPlans       ProductionPlan[]
  gumboBatches          GumboBatch[]
  orderStatusEvents     OrderStatusEvent[]
  reports               Report[]

  @@index([role])
}

model Employee {
  id        String    @id @default(cuid())
  userId    String?   @unique
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  firstName String
  lastName  String
  position  String?
  payRate   Decimal?  @db.Decimal(10, 2)
  hiredAt   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  timeEntries TimeEntry[]
  shifts      Shift[]
  prepTasks   PrepTask[]
}

model TimeEntry {
  id           String    @id @default(cuid())
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int       @default(0)
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([employeeId, clockIn])
}

model Shift {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startsAt   DateTime
  endsAt     DateTime
  role       Role?
  published  Boolean  @default(false)
  notes      String?
  createdAt  DateTime @default(now())

  @@index([employeeId, startsAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
}

// ============================================================================
// Menu / Catalog
// ============================================================================

enum SpiceLevel {
  MILD
  SPICY
}

enum MenuSize {
  CUP
  BOWL
  LARGE_BOWL
  QUART
  HALF_GALLON
}

model MenuCategory {
  id          String     @id @default(cuid())
  key         String     @unique
  name        String
  description String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  items       MenuItem[]
}

model MenuItem {
  id              String       @id @default(cuid())
  slug            String       @unique
  name            String
  description     String?
  categoryId      String
  category        MenuCategory @relation(fields: [categoryId], references: [id])
  recipeId        String?      @unique
  recipe          Recipe?      @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  imageUrl        String?
  ingredientsText String[]
  spiceLevels     SpiceLevel[]
  basePrice       Decimal?     @db.Decimal(10, 2)
  isFeatured      Boolean      @default(false)
  weekendOnly     Boolean      @default(false)
  isActive        Boolean      @default(true)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  variants MenuVariant[]
  addOns   MenuItemAddOn[]

  @@index([categoryId])
}

/// Size/price options for a menu item (Cup, Bowl, Quart, ...).
model MenuVariant {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  size       MenuSize
  label      String
  ounces     Int?
  price      Decimal  @db.Decimal(10, 2)
  isActive   Boolean  @default(true)

  orderItems     OrderItem[]
  packagingRules PackagingRule[]

  @@unique([menuItemId, size])
}

model AddOn {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  price           Decimal          @db.Decimal(10, 2)
  weekendOnly     Boolean          @default(false)
  isActive        Boolean          @default(true)
  inventoryItemId String?
  inventoryItem   InventoryItem?   @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  menuItems       MenuItemAddOn[]
  orderItemAddOns OrderItemAddOn[]
}

model MenuItemAddOn {
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  addOnId    String
  addOn      AddOn    @relation(fields: [addOnId], references: [id], onDelete: Cascade)

  @@id([menuItemId, addOnId])
}

// ============================================================================
// Inventory (canonical items, lots, ledger)
// ============================================================================

enum UnitType {
  WEIGHT
  VOLUME
  EACH
}

enum StorageType {
  DRY
  FREEZER
  WALK_IN_COOLER
  OTHER
}

enum InventoryTxnType {
  RECEIVE
  USE
  ADJUST
  WASTE
  COUNT
  TRANSFER
}

model Unit {
  id           String   @id @default(cuid())
  name         String   @unique
  abbreviation String   @unique
  type         UnitType

  inventoryItems     InventoryItem[]
  recipeIngredients  RecipeIngredient[]
  purchaseOrderLines PurchaseOrderLine[]
}

model InventoryCategory {
  id        String          @id @default(cuid())
  name      String          @unique
  sortOrder Int             @default(0)
  items     InventoryItem[]
}

model StorageLocation {
  id    String          @id @default(cuid())
  name  String          @unique
  type  StorageType     @default(DRY)
  items InventoryItem[]
}

model Supplier {
  id            String   @id @default(cuid())
  name          String   @unique
  type          String?
  contactName   String?
  phone         String?
  email         String?
  address       String?
  accountNumber String?
  notes         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  lots           InventoryLot[]
  priceHistory   PriceHistory[]
}

model InventoryItem {
  id                String             @id @default(cuid())
  name              String
  sku               String?            @unique
  barcode           String?
  categoryId        String?
  category          InventoryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  unitId            String
  unit              Unit               @relation(fields: [unitId], references: [id])
  storageLocationId String?
  storageLocation   StorageLocation?   @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  primarySupplierId String?
  primarySupplier   Supplier?          @relation(fields: [primarySupplierId], references: [id], onDelete: SetNull)
  costPerUnit       Decimal            @default(0) @db.Decimal(10, 4)
  parLevel          Decimal            @default(0) @db.Decimal(12, 3)
  reorderPoint      Decimal?           @db.Decimal(12, 3)
  onHand            Decimal            @default(0) @db.Decimal(12, 3)
  isPackaging       Boolean            @default(false)
  trackExpiration   Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  lots               InventoryLot[]
  transactions       InventoryTransaction[]
  priceHistory       PriceHistory[]
  recipeIngredients  RecipeIngredient[]
  purchaseOrderLines PurchaseOrderLine[]
  shoppingListItems  ShoppingListItem[]
  reorderSuggestions ReorderSuggestion[]
  wasteLogs          WasteLog[]
  cycleCountLines    CycleCountLine[]
  prepTasks          PrepTask[]
  gumboBatchItems    GumboBatchItem[]
  packagingRules     PackagingRule[]
  addOns             AddOn[]

  @@index([categoryId])
  @@index([isPackaging])
}

model InventoryLot {
  id                  String             @id @default(cuid())
  inventoryItemId     String
  inventoryItem       InventoryItem      @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity            Decimal            @db.Decimal(12, 3)
  remainingQuantity   Decimal            @db.Decimal(12, 3)
  unitCost            Decimal            @db.Decimal(10, 4)
  lotCode             String?
  receivedAt          DateTime           @default(now())
  expiresAt           DateTime?
  supplierId          String?
  supplier            Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrderLineId String?
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId, receivedAt])
  @@index([expiresAt])
}

model InventoryTransaction {
  id              String           @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  type            InventoryTxnType
  quantityDelta   Decimal          @db.Decimal(12, 3)
  unitCost        Decimal?         @db.Decimal(10, 4)
  balanceAfter    Decimal?         @db.Decimal(12, 3)
  reason          String?
  referenceType   String?
  referenceId     String?
  userId          String?
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())

  @@index([inventoryItemId, createdAt])
  @@index([type])
}

model PriceHistory {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplierId      String?
  supplier        Supplier?     @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  unitCost        Decimal       @db.Decimal(10, 4)
  source          String        @default("MANUAL")
  effectiveAt     DateTime      @default(now())

  @@index([inventoryItemId, effectiveAt])
}

// ============================================================================
// Recipes / Costing
// ============================================================================

model Recipe {
  id            String   @id @default(cuid())
  name          String
  description   String?
  instructions  String?
  imageUrl      String?
  yieldQuantity Decimal? @db.Decimal(12, 3)
  yieldUnit     String?
  prepMinutes   Int?
  cookMinutes   Int?
  version       Int      @default(1)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ingredients  RecipeIngredient[]
  versions     RecipeVersion[]
  menuItem     MenuItem?
  gumboBatches GumboBatch[]
  prepTasks    PrepTask[]
}

model RecipeIngredient {
  id              String        @id @default(cuid())
  recipeId        String
  recipe          Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Decimal       @db.Decimal(12, 3)
  unitId          String
  unit            Unit          @relation(fields: [unitId], references: [id])
  note            String?

  @@index([recipeId])
}

/// Immutable snapshot of a recipe at a point in time (version history).
model RecipeVersion {
  id        String   @id @default(cuid())
  recipeId  String
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  version   Int
  snapshot  Json
  createdAt DateTime @default(now())

  @@unique([recipeId, version])
}

// ============================================================================
// Purchasing
// ============================================================================

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  number         String              @unique
  supplierId     String
  supplier       Supplier            @relation(fields: [supplierId], references: [id])
  status         PurchaseOrderStatus @default(DRAFT)
  estimatedTotal Decimal             @default(0) @db.Decimal(10, 2)
  actualTotal    Decimal?            @db.Decimal(10, 2)
  orderedAt      DateTime?
  expectedAt     DateTime?
  receivedAt     DateTime?
  notes          String?
  createdById    String?
  createdBy      User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  lines PurchaseOrderLine[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderLine {
  id                String         @id @default(cuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId   String
  inventoryItem     InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  quantity          Decimal        @db.Decimal(12, 3)
  unitId            String
  unit              Unit           @relation(fields: [unitId], references: [id])
  estimatedUnitCost Decimal        @db.Decimal(10, 4)
  actualUnitCost    Decimal?       @db.Decimal(10, 4)
  receivedQuantity  Decimal        @default(0) @db.Decimal(12, 3)
  lots              InventoryLot[]

  @@index([purchaseOrderId])
}

model ShoppingListItem {
  id                String        @id @default(cuid())
  inventoryItemId   String
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  suggestedQuantity Decimal       @db.Decimal(12, 3)
  neededBy          DateTime?
  note              String?
  isPurchased       Boolean       @default(false)
  createdAt         DateTime      @default(now())
}

model ReorderSuggestion {
  id                String        @id @default(cuid())
  inventoryItemId   String
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  parLevel          Decimal       @db.Decimal(12, 3)
  onHand            Decimal       @db.Decimal(12, 3)
  suggestedOrderQty Decimal       @db.Decimal(12, 3)
  forecastUsage     Decimal?      @db.Decimal(12, 3)
  weekOf            DateTime
  createdAt         DateTime      @default(now())

  @@index([weekOf])
}

// ============================================================================
// Production (prep, protein batches, gumbo batch calculator, packaging)
// ============================================================================

enum PrepStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum Protein {
  CHICKEN
  SAUSAGE
  SHRIMP
  BLUE_CRAB
}

enum BatchStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model ProductionPlan {
  id          String      @id @default(cuid())
  date        DateTime
  status      BatchStatus @default(PLANNED)
  notes       String?
  createdById String?
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  prepTasks PrepTask[]

  @@index([date])
}

model PrepTask {
  id               String          @id @default(cuid())
  productionPlanId String?
  productionPlan   ProductionPlan? @relation(fields: [productionPlanId], references: [id], onDelete: SetNull)
  recipeId         String?
  recipe           Recipe?         @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  inventoryItemId  String?
  inventoryItem    InventoryItem?  @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  title            String
  quantity         Decimal?        @db.Decimal(12, 3)
  unitLabel        String?
  assignedToId     String?
  assignedTo       Employee?       @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  status           PrepStatus      @default(PENDING)
  dueAt            DateTime?
  completedAt      DateTime?
  notes            String?
  createdAt        DateTime        @default(now())

  @@index([status])
  @@index([dueAt])
}

model ProteinPrepBatch {
  id           String    @id @default(cuid())
  protein      Protein
  rawWeight    Decimal   @db.Decimal(12, 3)
  yieldWeight  Decimal?  @db.Decimal(12, 3)
  yieldPercent Decimal?  @db.Decimal(5, 2)
  preppedAt    DateTime  @default(now())
  expiresAt    DateTime?
  notes        String?

  @@index([protein, preppedAt])
}

model GumboBatch {
  id               String      @id @default(cuid())
  recipeId         String?
  recipe           Recipe?     @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  gumboType        String
  batchSizeGallons Int
  scaleFactor      Decimal     @db.Decimal(8, 3)
  expectedPortions Int
  foodCost         Decimal?    @db.Decimal(10, 2)
  status           BatchStatus @default(PLANNED)
  producedAt       DateTime?
  producedById     String?
  producedBy       User?       @relation(fields: [producedById], references: [id], onDelete: SetNull)
  notes            String?
  createdAt        DateTime    @default(now())

  items GumboBatchItem[]

  @@index([gumboType])
}

model GumboBatchItem {
  id              String         @id @default(cuid())
  gumboBatchId    String
  gumboBatch      GumboBatch     @relation(fields: [gumboBatchId], references: [id], onDelete: Cascade)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  name            String
  quantity        Decimal        @db.Decimal(12, 3)
  unitLabel       String?
  cost            Decimal?       @db.Decimal(10, 2)
}

/// Maps a packaged size to the packaging inventory it consumes (auto-deduction).
model PackagingRule {
  id              String        @id @default(cuid())
  name            String
  size            MenuSize?
  menuVariantId   String?
  menuVariant     MenuVariant?  @relation(fields: [menuVariantId], references: [id], onDelete: SetNull)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantityPerUnit Decimal       @default(1) @db.Decimal(12, 3)
}

// ============================================================================
// Customers / Orders / Payments
// ============================================================================

enum OrderType {
  PICKUP
  DELIVERY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum DeliveryPlatform {
  IN_HOUSE
  UBER_EATS
  DOORDASH
}

enum DiscountType {
  PERCENT
  FIXED
}

model Customer {
  id         String   @id @default(cuid())
  supabaseId String?  @unique
  email      String
  name       String?
  phone      String?
  createdAt  DateTime @default(now())

  addresses CustomerAddress[]
  orders    Order[]

  @@index([email])
}

model CustomerAddress {
  id            String   @id @default(cuid())
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  line1         String
  line2         String?
  city          String
  state         String
  zip           String
  deliveryNotes String?
  isDefault     Boolean  @default(false)
  orders        Order[]
}

model Order {
  id            String           @id @default(cuid())
  number        String           @unique
  customerId    String?
  customer      Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  type          OrderType
  status        OrderStatus      @default(PENDING)
  channel       DeliveryPlatform @default(IN_HOUSE)
  addressId     String?
  address       CustomerAddress? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  contactName   String?
  contactPhone  String?
  contactEmail  String?
  subtotal      Decimal          @default(0) @db.Decimal(10, 2)
  discountTotal Decimal          @default(0) @db.Decimal(10, 2)
  taxAmount     Decimal          @default(0) @db.Decimal(10, 2)
  tipAmount     Decimal          @default(0) @db.Decimal(10, 2)
  deliveryFee   Decimal          @default(0) @db.Decimal(10, 2)
  total         Decimal          @default(0) @db.Decimal(10, 2)
  promoCodeId   String?
  promoCode     PromoCode?       @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  scheduledFor  DateTime?
  placedAt      DateTime         @default(now())
  notes         String?
  updatedAt     DateTime         @updatedAt

  items        OrderItem[]
  payment      Payment?
  delivery     Delivery?
  statusEvents OrderStatusEvent[]

  @@index([status])
  @@index([placedAt])
  @@index([channel])
}

model OrderItem {
  id            String       @id @default(cuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuVariantId String?
  menuVariant   MenuVariant? @relation(fields: [menuVariantId], references: [id], onDelete: SetNull)
  nameSnapshot  String
  sizeSnapshot  String?
  spiceLevel    SpiceLevel?
  quantity      Int          @default(1)
  unitPrice     Decimal      @db.Decimal(10, 2)
  lineTotal     Decimal      @db.Decimal(10, 2)
  notes         String?

  addOns OrderItemAddOn[]

  @@index([orderId])
}

model OrderItemAddOn {
  id           String    @id @default(cuid())
  orderItemId  String
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addOnId      String?
  addOn        AddOn?    @relation(fields: [addOnId], references: [id], onDelete: SetNull)
  nameSnapshot String
  price        Decimal   @db.Decimal(10, 2)
  quantity     Int       @default(1)
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider    String        @default("stub-payments")
  providerRef String?
  amount      Decimal       @db.Decimal(10, 2)
  tipAmount   Decimal       @default(0) @db.Decimal(10, 2)
  status      PaymentStatus @default(PENDING)
  method      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PromoCode {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  discountType   DiscountType
  amount         Decimal      @db.Decimal(10, 2)
  minSubtotal    Decimal?     @db.Decimal(10, 2)
  maxRedemptions Int?
  redemptions    Int          @default(0)
  startsAt       DateTime?
  endsAt         DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  orders Order[]
}

model OrderStatusEvent {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      OrderStatus
  note        String?
  createdById String?
  createdBy   User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())

  @@index([orderId, createdAt])
}

model Delivery {
  id           String           @id @default(cuid())
  orderId      String           @unique
  order        Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  platform     DeliveryPlatform @default(IN_HOUSE)
  driverName   String?
  trackingUrl  String?
  fee          Decimal?         @db.Decimal(10, 2)
  dispatchedAt DateTime?
  deliveredAt  DateTime?
}

// ============================================================================
// Waste / Counts
// ============================================================================

enum WasteReason {
  SPOILAGE
  OVERPRODUCTION
  EXPIRED
  EMPLOYEE
  OTHER
}

model WasteLog {
  id              String        @id @default(cuid())
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  quantity        Decimal       @db.Decimal(12, 3)
  reason          WasteReason
  cost            Decimal       @default(0) @db.Decimal(10, 2)
  note            String?
  userId          String?
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  @@index([reason, createdAt])
}

model CycleCount {
  id          String           @id @default(cuid())
  countedAt   DateTime         @default(now())
  countedById String?
  countedBy   User?            @relation(fields: [countedById], references: [id], onDelete: SetNull)
  note        String?
  lines       CycleCountLine[]
}

model CycleCountLine {
  id              String        @id @default(cuid())
  cycleCountId    String
  cycleCount      CycleCount    @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  expectedQty     Decimal       @db.Decimal(12, 3)
  countedQty      Decimal       @db.Decimal(12, 3)
  varianceCost    Decimal?      @db.Decimal(10, 2)
}

// ============================================================================
// Analytics / Reporting
// ============================================================================

model DeliveryPlatformStat {
  id            String           @id @default(cuid())
  platform      DeliveryPlatform
  date          DateTime
  orders        Int              @default(0)
  grossSales    Decimal          @default(0) @db.Decimal(10, 2)
  fees          Decimal          @default(0) @db.Decimal(10, 2)
  netSales      Decimal          @default(0) @db.Decimal(10, 2)
  refunds       Int              @default(0)
  cancelled     Int              @default(0)
  averageTicket Decimal          @default(0) @db.Decimal(10, 2)

  @@unique([platform, date])
  @@index([date])
}

model SalesSnapshot {
  id            String   @id @default(cuid())
  date          DateTime @unique
  grossSales    Decimal  @default(0) @db.Decimal(10, 2)
  netSales      Decimal  @default(0) @db.Decimal(10, 2)
  orderCount    Int      @default(0)
  customerCount Int      @default(0)
  foodCost      Decimal  @default(0) @db.Decimal(10, 2)
  laborCost     Decimal  @default(0) @db.Decimal(10, 2)
  primeCost     Decimal  @default(0) @db.Decimal(10, 2)
  wasteCost     Decimal  @default(0) @db.Decimal(10, 2)

  @@index([date])
}

model Report {
  id            String   @id @default(cuid())
  type          String
  periodStart   DateTime
  periodEnd     DateTime
  format        String
  url           String?
  generatedById String?
  generatedBy   User?    @relation(fields: [generatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([type, createdAt])
}

// ============================================================================
// Marketing intake (catering, contact, reviews)
// ============================================================================

model CateringInquiry {
  id        String    @id @default(cuid())
  name      String
  email     String
  phone     String?
  eventDate DateTime?
  headcount Int?
  details   String?
  status    String    @default("NEW")
  createdAt DateTime  @default(now())

  @@index([status, createdAt])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model Review {
  id          String   @id @default(cuid())
  name        String
  location    String?
  rating      Int      @default(5)
  quote       String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([isPublished])
}
