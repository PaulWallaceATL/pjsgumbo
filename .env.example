# ----------------------------------------------------------------------------
# PJ's Gumbo Platform — environment variables
# Copy to `.env` and fill in. Never commit real secrets.
# ----------------------------------------------------------------------------

# Database (Supabase Postgres). Prisma 7 uses a single DATABASE_URL via the
# pg driver adapter and prisma.config.ts. Use the direct (session, port 5432)
# connection so Prisma Migrate works correctly.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# Supabase Auth + Storage
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[PUBLISHABLE-OR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[SERVICE-ROLE-KEY]" # server only — never expose

# Stripe (payments) — wired in the ordering/checkout phase
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend (transactional email)
RESEND_API_KEY=""
EMAIL_FROM="PJ's Gumbo <orders@pjsgumbo.com>"

# SMS provider (order notifications)
SMS_API_KEY=""
SMS_FROM_NUMBER=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
